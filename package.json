{
    "name": "cstradeup-extention",
    "version": "0.1.0",
    "description": "Analyze your CS2 inventory for profitable trade ups. Investment Inventory Insights. View hidden skins on steam inventory.",
    "main": ".eslintrc",
    "directories": {
        "lib": "src/lib"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/csfloat/extension.git"
    },
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('./build', { recursive: true, force: true })\"",
        "build:ts": "tsc",
        "build:css": "tailwindcss -i src/styles/tailwind.css -o styles.css --minify",
        "build": "npm run clean && npm run build:ts && npm run build:css && node esbuild.config.js && node ./scripts/copy-static.js",
        "watch:css": "tailwindcss -i src/styles/tailwind.css -o styles.css --watch",
        "build:webpack": "npm run build:css && NODE_ENV=production webpack --config webpack.config.js"
    },
    "homepage": "https://github.com/cstradeup/extension#readme",
    "devDependencies": {
        "@babel/core": "^7.20.12",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/preset-env": "^7.20.2",
        "@babel/preset-react": "^7.18.6",
        "@types/chrome": "^0.1.28",
        "@types/node": "^20.4.10",
        "@types/react": "^18.0.26",
        "@types/react-dom": "^18.0.10",
        "@types/react-router-dom": "^5.3.3",
        "@types/redux-logger": "^3.0.9",
        "@types/webextension-polyfill": "^0.10.7",
        "autoprefixer": "^10.4.21",
        "babel-eslint": "^10.1.0",
        "babel-loader": "^9.1.2",
        "buffer": "^6.0.3",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^11.0.0",
        "css-loader": "^6.7.3",
        "daisyui": "^5.5.5",
        "esbuild": "^0.25.12",
        "esbuild-plugin-polyfill-node": "^0.3.0",
        "file-loader": "^6.2.0",
        "fs-extra": "^11.1.0",
        "html-loader": "^4.2.0",
        "html-webpack-plugin": "^5.5.0",
        "path-browserify": "^1.0.1",
        "postcss": "^8.5.6",
        "process": "^0.11.10",
        "stream-browserify": "^3.0.0",
        "tailwindcss": "^4.1.17",
        "terser-webpack-plugin": "^5.3.6",
        "ts-loader": "^9.4.2",
        "type-fest": "^3.5.2",
        "typescript": "^5.5.0",
        "util": "^0.12.5",
        "webextension-polyfill": "^0.10.0",
        "webpack": "^5.75.0",
        "webpack-cli": "^4.10.0",
        "webpack-dev-server": "^4.11.1",
        "webpack-ext-reloader": "^1.1.12",
        "zip-webpack-plugin": "^4.0.1"
    },
    "dependencies": {
        "comlink": "^4.4.2",
        "tlsn-js": "0.1.0-alpha.12.0"
    }
}