{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["DOM", "ES2020"],
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"]
}